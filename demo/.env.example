# OAuth Provider Client IDs
# Copy this file to .env and fill in your credentials
# See docs/PROVIDER_SETUP_GUIDE.md for setup instructions

VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_APPLE_CLIENT_ID=your-apple-services-id
VITE_FACEBOOK_CLIENT_ID=your-facebook-app-id
VITE_GITHUB_CLIENT_ID=your-github-client-id
# OAuth Redirect URI (optional - auto-detected from current URL if not set)
# VITE_REDIRECT_URI=http://localhost:5173/callback
